# Smart Classroom Assistant — Environment Template
# Copy this file to .env and fill in your credentials.

# --- Core Services ---
# MongoDB Atlas Connection URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/smart_classroom

# Secret Key for JWT Token Generation (use a long random string)
SECRET_KEY=change-this-in-production-for-security

# --- AI & Processing ---
# Groq API Key (Llama-3) - Used for primary session analysis
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini API Key - Used for supplementary AI features
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# YouTube Data API v3 Key - Used for educational resource fetching
YOUTUBE_API_KEY=AIzaSy_your_youtube_api_key_here

# --- Optional / Local Paths ---
# HuggingFace Cache Path (for local Whisper model)
HF_HOME=D:\huggingface_cache
